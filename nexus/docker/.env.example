# ============================================================
#  Nexus / Nginx 環境變數
#  複製本檔案為 .env，填入實際值後執行 docker compose up
#  注意：.env 已加入 .gitignore，不可 commit 進版本控制
# ============================================================

# Nexus 對外 hostname（填入公司內部 DNS 或 IP）
NEXUS_HOST=nexus.internal

# Nexus 初始管理員密碼
# 首次啟動後可從容器內 /nexus-data/admin.password 取得
# 登入 Web UI 後請立即修改並更新此變數
NEXUS_ADMIN_PASSWORD=

# Nginx SSL 憑證檔名（放在 nexus/nginx/certs/ 目錄下）
SSL_CERT=nexus.crt
SSL_KEY=nexus.key

# (選用) 若有 upstream proxy 請填入，否則留空
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
